<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
        INTERNET is required only when online suggestion APIs are enabled.
        VIBRATE (for haptic feedback) can be added here when that feature is implemented.
    -->

    <application
        android:allowBackup="false"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.AppCompat.Light.NoActionBar">

        <!--
            Required by the Flutter 3.x tool to recognise this as an Android v2
            embedding project. Without it the tool defaults to v1 and refuses to
            build with "Build failed due to use of deleted Android v1 embedding."
        -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />

        <!--
            Launcher activity: hosts the Flutter settings/onboarding UI and
            allows the user to open the app from the home screen.
        -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <meta-data
                android:name="io.flutter.embedding.android.NormalTheme"
                android:resource="@style/NormalTheme" />
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            InputMethodService declaration.
            The service exposes the BIND_INPUT_METHOD permission so only the
            system can bind to it, and the meta-data points to the method
            descriptor XML that lists supported subtypes.
        -->
        <service
            android:name=".SmartKeyboardService"
            android:exported="true"
            android:label="@string/ime_name"
            android:permission="android.permission.BIND_INPUT_METHOD">
            <intent-filter>
                <action android:name="android.view.InputMethod" />
            </intent-filter>
            <meta-data
                android:name="android.view.im"
                android:resource="@xml/method" />
        </service>

    </application>

</manifest>
